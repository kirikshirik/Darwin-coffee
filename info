client.py

from __future__ import annotations
from datetime import datetime
from typing import Any
import httpx
class EvotorClient:
    BASE_URL = "https://api.evotor.ru"
    def __init__(
        self,
        token: str,
        timeout: int = 30,
    ) -> None:
        self.token = token
        self.timeout = timeout
    @property
    def headers(self) -> dict[str, str]:
        return {
            "Authorization": f"Bearer {self.token}",
            "Content-Type": "application/json",
            "Accept": "application/json",
        }
    async def _get(
        self,
        endpoint: str,
        params: dict[str, Any] | None = None,
    ) -> dict:
        async with httpx.AsyncClient(
            timeout=self.timeout
        ) as client:
            response = await client.get(
                f"{self.BASE_URL}{endpoint}",
                headers=self.headers,
                params=params,
            )
            response.raise_for_status()
            return response.json()
    async def get_stores(self) -> list[dict]:
        """
        Получение магазинов.
        """
        data = await self._get("/api/v1/inventories/stores")
        return data.get("items", [])
    async def get_products(
        self,
        store_uuid: str,
    ) -> list[dict]:
        """
        Получение товаров магазина.
        """
        data = await self._get(
            f"/api/v1/inventories/stores/{store_uuid}/products"
        )
        return data.get("items", [])
    async def get_documents(
        self,
        store_uuid: str,
        date_from: datetime,
        date_to: datetime,
    ) -> list[dict]:
        """
        Продажи и чеки за период.
        """
        data = await self._get(
            f"/api/v1/inventories/stores/{store_uuid}/documents",
            params={
                "dateFrom": date_from.isoformat(),
                "dateTo": date_to.isoformat(),
            },
        )
        return data.get("items", [])
    async def get_receipts_today(
        self,
        store_uuid: str,
    ) -> list[dict]:
        now = datetime.now()
        start = now.replace(
            hour=0,
            minute=0,
            second=0,
            microsecond=0,
        )
        return await self.get_documents(
            store_uuid,
            start,
            now,
        )

