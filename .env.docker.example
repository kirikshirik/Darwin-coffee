# Пример переменных окружения для Docker запуска
# Копируй значения в docker-compose.yml → environment section

# === Обязательные ===
PORT=8000

# === Telegram бот (опционально, но нужны для функционала) ===
# Получи токен: https://t.me/botfather → /newbot
TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11

# Твой Telegram ID (узнай через https://t.me/userinfobot)
TELEGRAM_OWNER_CHAT_ID=987654321

# === Таймзоны и расписание ===
TELEGRAM_TZ=Europe/Moscow
TELEGRAM_REPORT_TIME=09:00
EVOTOR_TZ=Europe/Moscow
EVOTOR_SYNC_INTERVAL_MIN=15

# === Эвотор API (опционально) ===
# Пусто = демо режим (используются mock данные)
EVOTOR_CLOUD_TOKEN=

# === Дашборд (опционально) ===
# Секрет для доступа к /dashboard?key=... и /api/dashboard
# Если пусто → маршруты выключены (404)
DASHBOARD_TOKEN=your-secret-dashboard-key

# === База данных (по умолчанию SQLite) ===
# Раскомментируй для Postgres:
# DATABASE_URL=postgresql://darwin:localdev123@postgres:5432/darwin_coffee
