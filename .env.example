# Darwin Coffee — пример переменных окружения.
# Скопируй в .env и заполни. Файл .env в git НЕ коммитится (см. .gitignore).

# --- База данных --------------------------------------------------------------
# По умолчанию локальный SQLite (backend/db.py). На проде — PostgreSQL:
# DATABASE_URL=postgresql+psycopg://user:pass@host:5432/darwin

# --- Эвотор (Облако) ----------------------------------------------------------
# БЛОКЕР №1: облачный токен аккаунта «Дарвина». Берётся в личном кабинете Эвотора.
# Без него интеграция работает только на образцах: python -m backend.integrations.evotor.demo
EVOTOR_CLOUD_TOKEN=

# Ниже значения по умолчанию уже сверены с developer.evotor.ru — менять обычно не нужно.
# EVOTOR_BASE_URL=https://api.evotor.ru
# EVOTOR_AUTH_HEADER=X-Authorization        # для OAuth-доступа: Authorization
# EVOTOR_AUTH_SCHEME=                        # для OAuth: Bearer
# EVOTOR_MEDIA_TYPE=application/vnd.evotor.v2+json
# EVOTOR_TIMEOUT=30
# EVOTOR_MONEY_IN_KOPECKS=0                  # 1, если в реале деньги придут в копейках

# --- Telegram-бот -------------------------------------------------------------
# Токен бота от @BotFather. Без него поллинг не стартует (логику можно гонять
# без токена: python -m backend.bot.demo).
TELEGRAM_BOT_TOKEN=

# Chat ID владельца — куда слать утреннюю сводку. Узнать: написать боту и
# посмотреть update, либо @userinfobot. Если пусто — утренняя рассылка выключена.
TELEGRAM_OWNER_CHAT_ID=

# Время и таймзона утренней сводки.
# TELEGRAM_TZ=Europe/Moscow
# TELEGRAM_REPORT_TIME=09:00
