# Darwin Coffee — пример переменных окружения.
# Скопируй в .env и заполни СВОИМИ значениями. Файл .env в git НЕ коммитится
# (см. .gitignore). Никогда не клади реальные токены в этот пример.

# --- База данных --------------------------------------------------------------
# По умолчанию локальный SQLite (backend/db.py) — этого достаточно для одной
# кофейни на VPS (включён WAL, бот-читатель и синк-писатель не мешают друг другу).
# Для PostgreSQL раскомментируй и поставь psycopg (см. DEPLOY.md):
# DATABASE_URL=postgresql+psycopg://user:pass@localhost:5432/darwin

# --- Эвотор (Облако) ----------------------------------------------------------
# Облачный токен аккаунта кофейни. Берётся в кабинете разработчика Эвотора.
# Без него синк не работает; маппинг можно проверить офлайн:
#   python -m backend.integrations.evotor.demo
EVOTOR_CLOUD_TOKEN=

# Таймзона магазина — в неё переводится время чеков из Эвотора (он отдаёт UTC).
# Влияет на «прибыльные часы» и границы суток в отчётах.
EVOTOR_TZ=Europe/Moscow

# Ниже значения по умолчанию уже сверены с developer.evotor.ru — менять обычно не нужно.
# EVOTOR_BASE_URL=https://api.evotor.ru
# EVOTOR_AUTH_HEADER=X-Authorization        # для OAuth-доступа: Authorization
# EVOTOR_AUTH_SCHEME=                        # для OAuth: Bearer
# EVOTOR_MEDIA_TYPE=application/vnd.evotor.v2+json
# EVOTOR_TIMEOUT=30
# EVOTOR_MONEY_IN_KOPECKS=0                  # 1, если деньги придут в копейках (у «Дарвина» — рубли)

# --- Telegram-бот -------------------------------------------------------------
# Токен бота от @BotFather. Без него поллинг не стартует.
TELEGRAM_BOT_TOKEN=

# Chat ID владельца — куда слать утреннюю сводку. Узнать: написать боту /start
# и посмотреть update, либо @userinfobot. Если пусто — утренняя рассылка выключена.
TELEGRAM_OWNER_CHAT_ID=

# Время и таймзона утренней сводки.
# TELEGRAM_TZ=Europe/Moscow
# TELEGRAM_REPORT_TIME=09:00
